#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage:
  ./export_stl <name-without-extension> [--source path/to/model.scad] [-- <openscad args>]

Examples:
  ./export_stl iphoneHolder
  ./export_stl bolt --source models/2026-07-02_sample_screw_and_hole.scad -- -D show_plate=false
EOF
}

if [[ $# -lt 1 ]]; then
    usage >&2
    exit 2
fi

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    usage
    exit 0
fi

output_name="$1"
shift

if [[ "$output_name" == *.stl || "$output_name" == *.scad ]]; then
    echo "Use a name without extension: ${output_name}" >&2
    exit 2
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source_scad="${script_dir}/models/${output_name}.scad"
openscad_args=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --source)
            if [[ $# -lt 2 ]]; then
                echo "--source requires a .scad path" >&2
                exit 2
            fi
            source_scad="$2"
            shift 2
            ;;
        --)
            shift
            openscad_args=("$@")
            break
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

if [[ "${source_scad}" != /* ]]; then
    source_scad="${script_dir}/${source_scad}"
fi

if [[ ! -f "${source_scad}" ]]; then
    echo "SCAD file not found: ${source_scad}" >&2
    exit 1
fi

if ! command -v openscad >/dev/null 2>&1; then
    echo "openscad executable not found in PATH" >&2
    exit 1
fi

mkdir -p "${script_dir}/stl"
today="$(date +%F)"
output_stl="${script_dir}/stl/${today}_${output_name}.stl"

echo "Rendering ${source_scad}"
echo "Exporting ${output_stl}"

if [[ ${#openscad_args[@]} -gt 0 ]]; then
    openscad "${openscad_args[@]}" -o "${output_stl}" "${source_scad}"
else
    openscad -o "${output_stl}" "${source_scad}"
fi

echo "Done: ${output_stl}"
